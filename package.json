{
    "name": "lab-react-router",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev:data-mode": "npm run dev -w @lab-react-router/data-mode",
        "dev:declarative-mode": "npm run dev -w @lab-react-router/declarative-mode",
        "dev:framework-mode": "npm run dev -w @lab-react-router/framework-mode",
        "dev:framework-mode-fs": "npm run dev -w @lab-react-router/framework-mode-fs",
        "build:all": "npm run build --workspaces",
        "build:gh": "npm run build --workspaces"
    }
}